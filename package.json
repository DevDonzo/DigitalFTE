{
  "name": "digital-fte",
  "version": "0.1.0",
  "description": "Personal AI Employee - Autonomous FTE using AI Assistant + Obsidian",
  "main": "scripts/control_center.py",
  "type": "module",
  "scripts": {
    "install:all": "npm install && pip install -r requirements.txt",
    "start": "./start_all.sh",
    "start:control-center": "python3 scripts/control_center.py",
    "start:orchestrator": "python3 scripts/orchestrator.py",
    "start:webhook": "python3 scripts/webhook_server.py",
    "start:watchdog": "python3 scripts/watchdog.py",
    "briefing": "python3 scripts/weekly_audit.py",
    "test": "pytest -q",
    "lint": "eslint . && flake8 .",
    "format": "prettier --write . && black .",
    "dev": "python3 scripts/control_center.py"
  },
  "keywords": [
    "AI",
    "automation",
    "FTE",
    "AI",
    "Obsidian"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.2",
    "node-fetch": "^3.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
